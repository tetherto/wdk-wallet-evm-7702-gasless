{
  "name": "@tetherto/wdk-wallet-evm-7702-gasless",
  "version": "1.0.0-beta.1",
  "description": "A simple package to manage BIP-32 wallets for evm blockchains, which implement the eip-7702 standard for gasless account abstraction",
  "keywords": [
    "wdk",
    "wallet",
    "bip-32",
    "ethereum",
    "eip-7702",
    "erc-4337",
    "account-abstraction",
    "gasless"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/tetherto/wdk-wallet-evm-7702-gasless.git"
  },
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns=/tests/integration/",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --testPathIgnorePatterns=/tests/integration/",
    "test:integration-wait": "wait-on http://localhost:8545 && cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/integration --forceExit",
    "test:integration-wait:coverage": "wait-on http://localhost:8545 && cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/integration --coverage --forceExit",
    "test:integration": "concurrently -k -s first -n \"NODE,TEST\" -c \"black,green\" --hide NODE \"npx hardhat node\" \"npm run test:integration-wait\"",
    "test:integration:coverage": "concurrently -k -s first -n \"NODE,TEST\" -c \"black,green\" --hide NODE \"npx hardhat node\" \"npm run test:integration-wait:coverage\""
  },
  "dependencies": {
    "@tetherto/wdk-wallet": "1.0.0-beta.7",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.12",
    "abstractionkit": "0.3.8",
    "bare-node-runtime": "1.2.0",
    "ethers": "6.14.4",
    "viem": "2.47.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "4.0.13",
    "@pimlico/alto": "0.0.19",
    "@pimlico/mock-paymaster": "0.0.4",
    "concurrently": "9.2.0",
    "cross-env": "7.0.3",
    "hardhat": "3.9.0",
    "jest": "29.7.0",
    "prool": "0.0.23",
    "standard": "17.1.2",
    "typescript": "5.8.3",
    "wait-on": "8.0.4"
  },
  "overrides": {
    "axios": "1.13.5",
    "cookie": "1.0.2",
    "tar": "7.5.7",
    "tmp": "0.2.5",
    "undici": "7.21.0",
    "ws": "8.18.3",
    "ox": "0.14.5"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  },
  "jest": {
    "collectCoverageFrom": ["src/**/*.js"]
  }
}
